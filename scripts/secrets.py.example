# Copy this file to secrets.py and fill in your tokens.
# secrets.py is git-ignored — never commit your actual tokens.
#
# HF_TOKEN: Get from https://huggingface.co/settings/tokens
#   You also need to accept the user agreements for:
#     - pyannote/speaker-diarization-3.1
#     - pyannote/segmentation-3.0
#
# SATT_USERNAME / SATT_PASSWORD: Your saltallthethings.com login credentials.
#   The watcher logs in automatically to get a fresh token before each scan.

HF_TOKEN = "your_huggingface_token_here"
SATT_USERNAME = "your_username_here"
SATT_PASSWORD = "your_password_here"
