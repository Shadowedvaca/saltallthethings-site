# Copy this file to secrets.py and fill in your tokens.
# secrets.py is git-ignored — never commit your actual tokens.
#
# HF_TOKEN: Get from https://huggingface.co/settings/tokens
#   You also need to accept the user agreements for:
#     - pyannote/speaker-diarization-3.1
#     - pyannote/segmentation-3.0
#
# SATT_API_TOKEN: Log in at https://saltallthethings.com, then copy the JWT
#   from your browser's localStorage (key: satt_jwt). This token expires after
#   8 hours — paste a fresh one here whenever the watcher stops authenticating.

HF_TOKEN = "your_huggingface_token_here"
SATT_API_TOKEN = "your_jwt_token_here"  # JWT from saltallthethings.com login
